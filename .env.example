# ThreadOS Core - Environment Variables Example
# 
# Copy this file to .env and fill in real values.
# The .env file is gitignored and should NEVER be committed.

# ----------------------------------------------------------------------------
# Database connection
# ----------------------------------------------------------------------------
# In Codespaces development, PostgreSQL runs locally with default credentials.
# In production, these will come from Google Secret Manager.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=threados_dev
DB_USER=postgres
DB_PASSWORD=postgres

# ----------------------------------------------------------------------------
# PII Hashing
# ----------------------------------------------------------------------------
# In production, this comes from Google Secret Manager and is rotated regularly.
# In development, any non-trivial value is fine but should not be shared publicly.

PII_HASH_SALT=threados_dev_salt_replace_in_production